# Supabase (Project Settings → API) — copy to .env (never commit real keys here)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only for server-side scripts (seed + ESPN sync — never use in the Expo app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub Actions (same values as secrets — see README “Automated cron”)
# EXPO_PUBLIC_SUPABASE_URL or SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY

# ESPN sync: npm run sync:all (daily) | sync:live:basketball (1 min) | sync:live:other (3 min)
